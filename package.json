{
  "name": "winccoa-core",
  "displayName": "WinCC OA Control",
  "description": "Central control and monitoring for WinCC OA projects - project management, system status, and manager control",
  "publisher": "winccoa-tools-pack",
  "version": "0.2.0",
  "author": "winccoa-tools-pack",
  "license": "MIT",
  "icon": "resources/wincc_oa_core_512.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/winccoa-tools-pack/vscode-winccoa-core"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "wincc-oa",
    "wincc",
    "oa",
    "scada",
    "siemens",
    "core",
    "library",
    "shared"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "winccoa-control",
          "title": "WinCC OA Control",
          "icon": "resources/sidebar_industrial_calm_128.png"
        }
      ]
    },
    "views": {
      "winccoa-control": [
        {
          "id": "winccoa.systemView",
          "name": "System Status"
        },
        {
          "id": "winccoa.managerView",
          "name": "Managers"
        }
      ]
    },
    "commands": [
      {
        "command": "winccoa.core.selectProject",
        "title": "Select WinCC OA Project",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.core.refreshProjects",
        "title": "Refresh WinCC OA Projects",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.core.showProjectInfo",
        "title": "Show Current Project Info",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.manager.start",
        "title": "Start Manager",
        "category": "WinCC OA",
        "icon": "$(play)"
      },
      {
        "command": "winccoa.manager.stop",
        "title": "Stop Manager",
        "category": "WinCC OA",
        "icon": "$(stop)"
      },
      {
        "command": "winccoa.manager.restart",
        "title": "Restart Manager",
        "category": "WinCC OA",
        "icon": "$(debug-restart)"
      },
      {
        "command": "winccoa.system.start",
        "title": "Start PMON",
        "category": "WinCC OA",
        "icon": "$(play)"
      },
      {
        "command": "winccoa.system.stop",
        "title": "Stop PMON",
        "category": "WinCC OA",
        "icon": "$(stop)"
      },
      {
        "command": "winccoa.system.restart",
        "title": "Restart PMON",
        "category": "WinCC OA",
        "icon": "$(debug-restart)"
      },
      {
        "command": "winccoa.project.start",
        "title": "Start Project",
        "category": "WinCC OA",
        "icon": "$(play)"
      },
      {
        "command": "winccoa.project.stop",
        "title": "Stop Project",
        "category": "WinCC OA",
        "icon": "$(stop)"
      },
      {
        "command": "winccoa.project.restart",
        "title": "Restart Project",
        "category": "WinCC OA",
        "icon": "$(debug-restart)"
      },
      {
        "command": "winccoa.systemView.refresh",
        "title": "Refresh",
        "category": "WinCC OA",
        "icon": "$(refresh)"
      },
      {
        "command": "winccoa.managerView.refresh",
        "title": "Refresh",
        "category": "WinCC OA",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "winccoa.systemView.refresh",
          "when": "view == winccoa.systemView",
          "group": "navigation"
        },
        {
          "command": "winccoa.managerView.refresh",
          "when": "view == winccoa.managerView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "winccoa.manager.start",
          "when": "view == winccoa.managerView && viewItem == manager",
          "group": "inline"
        },
        {
          "command": "winccoa.manager.stop",
          "when": "view == winccoa.managerView && viewItem == manager",
          "group": "inline"
        },
        {
          "command": "winccoa.manager.restart",
          "when": "view == winccoa.managerView && viewItem == manager",
          "group": "inline"
        },
        {
          "command": "winccoa.project.start",
          "when": "view == winccoa.systemView && viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "winccoa.project.stop",
          "when": "view == winccoa.systemView && viewItem == project",
          "group": "inline@2"
        },
        {
          "command": "winccoa.project.restart",
          "when": "view == winccoa.systemView && viewItem == project",
          "group": "inline@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "build": "tsc --build",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules",
    "lint:md:fix": "markdownlint \"**/*.md\" --ignore node_modules --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\"",
    "style-check": "npm run lint && npm run format:check && npm run lint:md && npm run format:md:check",
    "style-fix": "npm run lint:fix && npm run format && npm run lint:md:fix && npm run format:md",
    "test": "npm run style-check && npm run compile && node ./dist/test/runTest.js",
    "test:integration": "npm run build && node ./dist/test/runTest.js",
    "ci:integration": "npm ci && npm run test:integration"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.50.0",
    "glob": "^13.0.0",
    "markdownlint-cli": "^0.47.0",
    "mocha": "^11.7.5",
    "prettier": "^2.8.8",
    "ts-loader": "^9.5.4",
    "typescript": "^5.2.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@winccoa-tools-pack/core-utils": "file:../npm-shared-library-core"
  }
}
